{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Minimart POS",
  "version": "0.1.0",
  "identifier": "com.njoroge.minimart-pos-tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Minimart POS",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "publisher": "njoroge",
    "category": "Business",
    "shortDescription": "Minimart POS System - Kenyan Retail Management",
    "longDescription": "A desktop point-of-sale and shop management system for Kenyan minimarts. Includes sales, product management, inventory adjustment, reports, receipt printing, VAT display, and a per-machine SQLite database initialized on first launch.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "active": false
    }
  }
}
